    <h2>Skills</h2>
    <p>${g}</p>

    <h2>Party (${(t||[]).length}/6)</h2>
    ${P||'<p style="color:#999;">No Pokémon in party.</p>'}

    <p style="text-align:center;font-size:11px;color:#aaa;margin-top:20px;">
        Generated by PTA3 Dex · ${new Date().toLocaleDateString()}
    </p>
</div>
