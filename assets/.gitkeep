",{children:"skill talents"}),"."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Class Slots"}),e.jsxs("ul",{style:{paddingLeft:"18px",margin:"0 0 10px",lineHeight:"1.8"},children:[e.jsxs("li",{children:[e.jsx("strong",{children:"Lv 1:"})," 1st class"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"Lv 3:"})," 2nd class"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"Lv 7:"})," 3rd class"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"Lv 11:"})," 4th class"]})]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Base vs Advanced"}),e.jsxs("p",{children:["Your ",e.jsx("strong",{children:"first class"})," must be one of the 7 Base classes. Additional slots unlock Advanced classes. Each class provides a ",e.jsx("strong",{children:"skill pool"})," — you gain talents in skills from that pool (max 2 talents per skill)."]})]})},"move-slots":{title:"Move Slots",body:()=>e.jsxs(e.Fragment,{children:[e.jsxs("p",{children:["Each Pokémon can know up to ",e.jsx("strong",{children:"6 moves"})," in a single pool — there is no distinction between Natural and Taught moves."]}),e.jsxs("p",{style:{margin:"10px 0"},children:["Moves come directly from the species' Pokédex entry. Frequencies are ",e.jsx("strong",{children:"At-Will"}),", ",e.jsx("strong",{children:"3/day"}),", or ",e.jsx("strong",{children:"1/day"}),"."]}),e.jsx("p",{style:{marginTop:"10px",fontSize:"12px",color:"var(--text-muted)"},children:"Tip: When all 6 slots are full, you'll be prompted to replace an existing move before learning a new one."})]})},"combat-stages":{title:"Combat Stages",body:()=>e.jsxs(e.Fragment,{children:[e.jsxs("p",{children:["Combat Stages track temporary ",e.jsx("strong",{children:"stat buffs and debuffs"})," applied by moves during battle."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Flat Stage Bonus"}),e.jsxs("ul",{style:{paddingLeft:"18px",margin:"0 0 10px",lineHeight:"1.8"},children:[e.jsxs("li",{children:[e.jsx("strong",{children:"+1 stage"})," = +2 flat to the stat"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"−1 stage"})," = −2 flat to the stat"]}),e.jsx("li",{children:"Example: ATK 8 at +3 stages → effective ATK 14"})]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Limits & Reset"}),e.jsxs("p",{children:["Stages range from ",e.jsx("strong",{children:"−6 to +6"})," (stat change: −12 to +12). They reset when the Pokémon switches out or the battle ends. Use the Reset button to clear all stages at once."]})]})},"save-slots":{title:"Save & Export",body:()=>e.jsxs(e.Fragment,{children:[e.jsx("p",{children:"PTA3 Dex offers two ways to preserve your data:"}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Save Slots (browser snapshots)"}),e.jsxs("p",{children:["Three named slots stored in your browser. Fast to create and restore — ideal for ",e.jsx("strong",{children:"mid-session checkpoints"}),". Note: these are browser-only and will be lost if you clear site data."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Export JSON (portable file)"}),e.jsxs("p",{children:["Downloads a ",e.jsx("code",{children:".json"})," file to your device. Use this for ",e.jsx("strong",{children:"backups"}),", sharing with others, or moving your data to a different browser or device. Import it back via the menu."]}),e.jsx("p",{style:{marginTop:"10px",fontSize:"12px",color:"var(--text-muted)"},children:"Tip: The app auto-saves to localStorage every minute. Use both slots and exports for peace of mind."})]})},"trainer-features":{title:"Trainer Features",body:()=>e.jsxs(e.Fragment,{children:[e.jsx("p",{children:"Features are special abilities granted automatically when your class level advances. There are no feat points — features are simply unlocked at each class level milestone."}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Auto-Granted Features"}),e.jsx("p",{children:"Every time your trainer levels up, each class also advances one level and automatically grants any features tied to that class level. You don't need to pick or buy them."}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Feature Drop"}),e.jsxs("p",{children:["When a new feature is granted, you may optionally ",e.jsx("strong",{children:"drop"})," it in exchange for ",e.jsx("strong",{children:"+1 to any stat"}),". You can do this up to ",e.jsx("strong",{children:"4 times"})," total across your career. If you keep all features, the prompt disappears."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Level 15 Capstone"}),e.jsxs("p",{children:["Only your ",e.jsx("strong",{children:"first base class"})," ever grants its Level 15 capstone feature. All other classes (advanced or secondary base) do not receive a Level 15 feature."]})]})},"trainer-skills":{title:"Trainer Skills",body:()=>e.jsxs(e.Fragment,{children:[e.jsxs("p",{children:["There are ",e.jsx("strong",{children:"18 skills"}),", each linked to one of the 5 trainer stats. Skill checks are ",e.jsx("strong",{children:"1d20 + ⌊stat ÷ 2⌋ + talent bonus"}),"."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Talent Bonus"}),e.jsxs("ul",{style:{paddingLeft:"18px",margin:"0 0 10px",lineHeight:"1.8"},children:[e.jsxs("li",{children:[e.jsx("strong",{children:"0 talents:"})," no bonus"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"1 talent:"})," +2"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"2 talents:"})," +5"]})]}),e.jsxs("p",{children:["Click a skill to cycle talents (0 → 1 → 2 → 0). ",e.jsx("strong",{children:"Concentration"})," and ",e.jsx("strong",{children:"Constitution"})," are passive — they are invoked by the GM, not rolled manually. Max 2 talents per skill."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Gaining Talents"}),e.jsx("p",{children:"Talents come from your class skill pools. Each class grants access to a set of skills; choosing a class lets you apply talents to those skills."})]})},"pokemon-stats":{title:"Pokémon Stats",body:()=>e.jsxs(e.Fragment,{children:[e.jsxs("p",{children:["Pokémon have ",e.jsx("strong",{children:"6 stats"})," (HP, ATK, DEF, SATK, SDEF, SPD). All stats are ",e.jsx("strong",{children:"fixed by the species"})," Pokédex entry — there are no level-up stat points to allocate."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Nature Modifier"}),e.jsxs("p",{children:["A Pokémon's nature raises one stat by ",e.jsx("strong",{children:"+1"})," and lowers another by ",e.jsx("strong",{children:"−1"}),". The five neutral natures (Hardy, Docile, Serious, Bashful, Quirky) have no effect."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"HP"}),e.jsxs("p",{children:["Max HP is the species HP stat after the nature modifier. It does ",e.jsx("em",{children:"not"})," scale with level."]})]})},"pokemon-skills":{title:"Pokémon Capabilities",body:()=>e.jsxs(e.Fragment,{children:[e.jsxs("p",{children:["Pokémon ",e.jsx("strong",{children:"capabilities"})," are named traits that describe what a Pokémon can do outside of battle. They are fixed by species and cannot be changed."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Examples"}),e.jsxs("ul",{style:{paddingLeft:"18px",margin:"0 0 10px",lineHeight:"1.8"},children:[e.jsxs("li",{children:[e.jsx("strong",{children:"Sprouter"})," — can grow plants through cracks in surfaces"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"Sinker"})," — can sink to the bottom of bodies of water"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"Firestarter"})," — can ignite flammable materials at will"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"Threaded"})," — can weave or spin thread-like substances"]})]}),e.jsx("p",{style:{marginTop:"10px",fontSize:"12px",color:"var(--text-muted)"},children:"Speed (in feet per round) is listed separately on the species entry."})]})},honors:{title:"Honors & Leveling",body:()=>e.jsxs(e.Fragment,{children:[e.jsxs("p",{children:[e.jsx("strong",{children:"Honors"})," represent your trainer's reputation and accomplishments. They determine when you can level up — ",e.jsx("em",{children:"they are not the same as Badges"}),"."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Sources of Honors"}),e.jsxs("ul",{style:{paddingLeft:"18px",margin:"0 0 10px",lineHeight:"1.8"},children:[e.jsxs("li",{children:[e.jsx("strong",{children:"Gym Badges"})," — each badge typically earns 1 Honor"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"Contest Ribbons"})," — each ribbon typically earns 1 Honor"]}),e.jsxs("li",{children:[e.jsx("strong",{children:"Story Milestones"})," — GM-awarded at major events"]})]}),e.jsxs("p",{children:["Badges are tracked separately as trophies. Earning a badge does ",e.jsx("em",{children:"not"})," automatically add an Honor — the GM awards them explicitly."]}),e.jsx("h4",{style:{margin:"14px 0 6px",fontSize:"13px",color:"var(--text-secondary)"},children:"Leveling Up"}),e.jsxs("p",{children:["Once you have enough Honors for the next level, click the ",e.jsx("strong",{children:"+"})," button next to your level. Leveling up does ",e.jsx("em",{children:"not"})," happen automatically when you earn honors."]}),e.jsxs("ul",{style:{paddingLeft:"18px",margin:"0 0 10px",lineHeight:"1.8"},children:[e.jsx("li",{children:"Levels 1–2: free (character creation)"}),e.jsx("li",{children:"Each level beyond that requires a set number of Honors"}),e.jsxs("li",{children:["Maximum trainer 